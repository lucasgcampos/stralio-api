generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
    personId    String      @id @db.VarChar(26)
    email       String      @unique
    name        String
    password    String
    document    String
    roleId      String
    createdAt   DateTime    @default(now())
    updatedAt   DateTime    @default(now()) @updatedAt
    role        Role        @relation(fields: [roleId], references: [id])
}

model Role {
    id          String       @id @db.VarChar(26)
    name        String
    users       User[]
}
